generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Type {
  id              Int           @id @default(autoincrement())
  name            String        @unique
  pokemonCards    PokemonCard[] @relation("PokemonCardType")
  weaknessCards   PokemonCard[] @relation("PokemonCardWeakness")
}

model PokemonCard {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  pokedexId   Int     @unique
  typeId      Int
  type        Type    @relation("PokemonCardType", fields: [typeId], references: [id])
  weaknessId  Int?
  weakness    Type?   @relation("PokemonCardWeakness", fields: [weaknessId], references: [id])
  lifePoints  Int
  size        Float?
  weight      Float?
  imageUrl    String?
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
}